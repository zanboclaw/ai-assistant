POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=change_me_for_validation
REDIS_URL=redis://redis:6379/0

LOG_DIR=/opt/ai-assistant/logs
CHECKPOINT_DIR=/opt/ai-assistant/data/checkpoints
ARTIFACT_DIR=/opt/ai-assistant/data/artifacts
WORKSPACE_DIR=/opt/ai-assistant/data/workspace
WORKSPACE_ROOT=/opt/ai-assistant

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
TAVILY_API_KEY=

AUTO_STAGE5_POSTRUN_ENABLED=1
CHANGE_GATE_ENFORCED_TARGET_TYPES=model_route,model_provider,tool_registry,risk_policy
DAILY_REVIEW_INTERVAL_SECONDS=3600
DAILY_REVIEW_SESSION_LIMIT=20
