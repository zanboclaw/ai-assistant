POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=inject_from_secret_manager
REDIS_URL=redis://redis:6379/0

LOG_DIR=/var/log/ai-assistant
CHECKPOINT_DIR=/var/lib/ai-assistant/checkpoints
ARTIFACT_DIR=/var/lib/ai-assistant/artifacts
WORKSPACE_DIR=/var/lib/ai-assistant/workspace
WORKSPACE_ROOT=/srv/ai-assistant

DEEPSEEK_API_KEY=inject_from_secret_manager
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
TAVILY_API_KEY=inject_from_secret_manager

AUTO_STAGE5_POSTRUN_ENABLED=1
CHANGE_GATE_ENFORCED_TARGET_TYPES=model_route,model_provider,tool_registry,risk_policy
DAILY_REVIEW_INTERVAL_SECONDS=3600
DAILY_REVIEW_SESSION_LIMIT=50
