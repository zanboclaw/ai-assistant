def normalize_step_name(step: str) -> str:
    step = (step or "").strip()
    step = re.sub(r"^\s*\d+[\.\)、:：]\s*", "", step)
    step = re.sub(r"^\s*第\s*\d+\s*步[\s:：\-]*", "", step)
    return step.strip()


def extract_path_from_text(text: str) -> str | None:
    match = re.search(r"(/[^\s'\"`，。；;,|><]+)", text or "")
    if match:
        return match.group(1).rstrip("`.,;:)")
    return None


def extract_dir_from_text(text: str) -> str | None:
    return extract_path_from_text(text)


def extract_command_from_text(text: str) -> str | None:
    patterns = [
        r"`([^`]+)`",
        r"命令[：:\s]+(.+)",
        r"执行[：:\s]+(.+)",
    ]
    for pattern in patterns:
        match = re.search(pattern, text or "")
        if match:
            return match.group(1).strip()
    return None


def path_looks_like_file(path_str: str) -> bool:
    if not path_str:
        return False
    return "." in Path(path_str).name


def path_looks_like_dir(path_str: str) -> bool:
    if not path_str:
        return False
    return not path_looks_like_file(path_str)


def is_path_in_allowed_dirs(path_str: str, allowed_dirs: list[Path]) -> bool:
    try:
        target = Path(path_str).resolve()
        for base in allowed_dirs:
            try:
                target.relative_to(base.resolve())
                return True
            except ValueError:
                continue
        return False
    except Exception:
        return False


def is_valid_reference(value: str) -> bool:
    return bool(re.match(r"^step:\d+\.(output|data)(\.[a-zA-Z_][a-zA-Z0-9_]*)*$", value))


def validate_input_value(tool_name: str, key: str, value: Any):
    if isinstance(value, str):
        if value in DEPRECATED_PLACEHOLDERS:
            raise ValueError(
                f"非法协议：检测到已废弃占位符 {value}，请改用 step:N.output"
            )

        if value.startswith("step:"):
            if not is_valid_reference(value):
                raise ValueError(f"非法协议：引用格式不合法 -> {value}")

    if key == "path":
        if not isinstance(value, str) or not value.strip():
            raise ValueError(f"非法协议：{tool_name}.input.path 必须是非空字符串")

    if key == "query":
        if not isinstance(value, str) or not value.strip():
            raise ValueError(f"非法协议：{tool_name}.input.query 必须是非空字符串")

    if key == "command":
        if not isinstance(value, str) or not value.strip():
            raise ValueError(f"非法协议：{tool_name}.input.command 必须是非空字符串")

    if key == "content":
        if not isinstance(value, str) or not value.strip():
            raise ValueError(f"非法协议：{tool_name}.input.content 必须是非空字符串")

    if key == "text":
        if not isinstance(value, str) or not value.strip():
            raise ValueError(f"非法协议：{tool_name}.input.text 必须是非空字符串")


def validate_and_normalize_steps(data: dict[str, Any]) -> list[dict[str, Any]]:
    if not isinstance(data, dict):
        raise ValueError("非法协议：顶层必须是 JSON 对象")

    steps = data.get("steps")
    if not isinstance(steps, list) or not steps:
        raise ValueError("非法协议：steps 必须是非空数组")

    normalized_steps: list[dict[str, Any]] = []
    seen_orders = set()

    for idx, step in enumerate(steps, start=1):
        if not isinstance(step, dict):
            raise ValueError(f"非法协议：第 {idx} 个 step 必须是对象")

        required_top_keys = {"step_order", "title", "tool", "input", "error_strategy"}
        missing_keys = required_top_keys - set(step.keys())
        if missing_keys:
            raise ValueError(
                f"非法协议：第 {idx} 个 step 缺少字段 -> {sorted(missing_keys)}"
            )

        step_order = step.get("step_order")
        title = step.get("title")
        tool = step.get("tool")
        input_payload = step.get("input")
        error_strategy = step.get("error_strategy")

        if not isinstance(step_order, int) or step_order <= 0:
            raise ValueError(f"非法协议：第 {idx} 个 step 的 step_order 必须为正整数")

        if step_order in seen_orders:
            raise ValueError(f"非法协议：step_order 重复 -> {step_order}")
        seen_orders.add(step_order)

        if not isinstance(title, str) or not title.strip():
            raise ValueError(f"非法协议：第 {idx} 个 step 的 title 必须是非空字符串")
        title = normalize_step_name(title)

        if not isinstance(tool, str) or not tool.strip():
            raise ValueError(f"非法协议：第 {idx} 个 step 的 tool 必须是非空字符串")
        tool = tool.strip()

        if tool not in ALLOWED_TOOLS:
            raise ValueError(f"非法协议：第 {idx} 个 step 的 tool 不在白名单中 -> {tool}")

        if error_strategy not in ALLOWED_ERROR_STRATEGIES:
            raise ValueError(
                f"非法协议：第 {idx} 个 step 的 error_strategy 不合法 -> {error_strategy}"
            )

        if not isinstance(input_payload, dict):
            raise ValueError(f"非法协议：第 {idx} 个 step 的 input 必须是对象")

        deprecated_keys_found = set(input_payload.keys()) & DEPRECATED_INPUT_KEYS
        if deprecated_keys_found:
            raise ValueError(
                f"非法协议：第 {idx} 个 step 使用了废弃字段 -> {sorted(deprecated_keys_found)}"
            )

        rule = TOOL_INPUT_RULES[tool]
        required_input_keys = rule["required"]
        optional_input_keys = rule["optional"]
        allowed_input_keys = required_input_keys | optional_input_keys

        actual_input_keys = set(input_payload.keys())

        missing_input_keys = required_input_keys - actual_input_keys
        if missing_input_keys:
            raise ValueError(
                f"非法协议：第 {idx} 个 step 的 {tool}.input 缺少字段 -> {sorted(missing_input_keys)}"
            )

        unexpected_input_keys = actual_input_keys - allowed_input_keys
        if unexpected_input_keys:
            raise ValueError(
                f"非法协议：第 {idx} 个 step 的 {tool}.input 存在非法字段 -> {sorted(unexpected_input_keys)}"
            )

        normalized_input = {}
        for k, v in input_payload.items():
            validate_input_value(tool, k, v)
            normalized_input[k] = v

        normalized_steps.append({
            "step_order": step_order,
            "title": title,
            "tool": tool,
            "input": normalized_input,
            "error_strategy": error_strategy,
        })

    normalized_steps.sort(key=lambda x: x["step_order"])
    return normalized_steps


def create_steps(cur, task_id: int, steps: list[dict[str, Any]]):
    for idx, step in enumerate(steps, start=1):
        step_order = step.get("step_order", idx)
        title = step.get("title", f"步骤{idx}")
        tool_name = step.get("tool", "")
        input_payload = json.dumps(step.get("input", {}), ensure_ascii=False)
        error_strategy = step.get("error_strategy", "fail")

        cur.execute(
            """
            INSERT INTO task_steps (
                task_id, step_order, step_name, tool_name, status, input_payload, error_strategy
            )
            VALUES (%s, %s, %s, %s, 'pending', %s, %s);
            """,
            (task_id, step_order, title, tool_name, input_payload, error_strategy),
        )


def write_artifact(task_id: int, user_input: str, step_outputs: list[str]) -> str:
    file_path = ARTIFACT_DIR / f"task_{task_id}.md"

    sections = []
    for idx, output in enumerate(step_outputs, start=1):
        sections.append(f"### 步骤 {idx}\n{output}")

    content = f"""# 任务结果

## 原始任务
{user_input}

## 执行步骤结果

{chr(10).join(sections)}
"""
    file_path.write_text(content, encoding="utf-8")
    return str(file_path)


def fallback_steps(user_input: str) -> list[dict[str, Any]]:
    path = extract_path_from_text(user_input)
    command = extract_command_from_text(user_input)

    if "命令" in user_input or "shell" in user_input or "终端" in user_input or command:
        return [
            {
                "step_order": 1,
                "title": "识别并执行安全命令",
                "tool": "shell_exec",
                "input": {"command": command or ""},
                "error_strategy": "fail",
            },
            {
                "step_order": 2,
                "title": "分析命令输出",
                "tool": "summarize_text",
                "input": {"text": "step:1.output"},
                "error_strategy": "fail",
            },
        ]

    if path and path_looks_like_dir(path):
        return [
            {
                "step_order": 1,
                "title": "列出目录内容",
                "tool": "list_dir",
                "input": {"path": path},
                "error_strategy": "fail",
            },
            {
                "step_order": 2,
                "title": "分析目录中的关键信息",
                "tool": "summarize_text",
                "input": {"text": "step:1.output"},
                "error_strategy": "fail",
            },
        ]

    if path and path_looks_like_file(path):
        if ("写入文件" in user_input or "保存到文件" in user_input or "输出到文件" in user_input):
            all_paths = re.findall(r"(/[^\s'\"`，。；;,|><]+)", user_input)
            cleaned = [p.rstrip("`.,;:)") for p in all_paths]

            source_path = cleaned[0] if len(cleaned) >= 1 else ""
            target_path = cleaned[1] if len(cleaned) >= 2 else ""

            return [
                {
                    "step_order": 1,
                    "title": "读取文件内容",
                    "tool": "file_read",
                    "input": {"path": source_path},
                    "error_strategy": "fail",
                },
                {
                    "step_order": 2,
                    "title": "整理当前结果",
                    "tool": "summarize_text",
                    "input": {"text": "step:1.output"},
                    "error_strategy": "fail",
                },
                {
                    "step_order": 3,
                    "title": "写入目标文件",
                    "tool": "file_write",
                    "input": {
                        "path": target_path,
                        "content": "step:2.output",
                    },
                    "error_strategy": "fail",
                },
            ]

        return [
            {
                "step_order": 1,
                "title": "读取文件内容",
                "tool": "file_read",
                "input": {"path": path},
                "error_strategy": "fail",
            },
            {
                "step_order": 2,
                "title": "分析文件关键信息",
                "tool": "summarize_text",
                "input": {"text": "step:1.output"},
                "error_strategy": "fail",
            },
        ]

    return [
        {
            "step_order": 1,
            "title": "搜索资料并收集关键信息",
            "tool": "web_search",
            "input": {"query": user_input},
            "error_strategy": "fail",
        },
        {
            "step_order": 2,
            "title": "整理并输出执行清单",
            "tool": "summarize_text",
            "input": {"text": "step:1.output"},
            "error_strategy": "fail",
        },
    ]


def call_deepseek_once(user_input: str) -> list[dict[str, Any]]:
    completion = client.chat.completions.create(
        model=MODEL_NAME,
        messages=[
            {
                "role": "system",
                "content": (
                    "你是任务规划器。"
                    "只允许输出合法 JSON，不允许输出解释、markdown、注释。"
                    "输出格式必须严格为："
                    '{"steps":[{"step_order":1,"title":"步骤标题","tool":"工具名","input":{},"error_strategy":"fail"}]}'
                    "tool 只能是：web_search, file_read, list_dir, file_write, shell_exec, summarize_text。"
                    "文件路径字段统一使用 path。"
                    "写文件内容字段统一使用 content。"
                    "搜索字段统一使用 query。"
                    "命令字段统一使用 command。"
                    "文本摘要字段统一使用 text。"
                    "不允许使用 file_path、dir_path。"
                    "不允许使用 [file_content]、[summarized_content] 这类占位符。"
                    "后续步骤引用必须使用 step:N.output 或 step:N.data.xxx。"
                    "error_strategy 只能是 fail 或 continue。"
                    "如果没有明确目标文件路径，不允许生成 file_write。"
                ),
            },
            {
                "role": "user",
                "content": user_input,
            },
        ],
        response_format={"type": "json_object"},
        temperature=0.2,
        max_tokens=1200,
    )

    message = completion.choices[0].message
    text = (message.content or "").strip()

    print(f"DeepSeek raw content: {text!r}")

    if not text:
        raise ValueError("DeepSeek 返回了空 content，无法解析 JSON")

    data = json.loads(text)

    # 仅保留过渡期兼容：字符串 steps
    steps = data.get("steps", [])
    if isinstance(steps, list) and steps and all(isinstance(step, str) for step in steps):
        normalized = []
        for idx, step in enumerate(steps, start=1):
            normalized.append({
                "step_order": idx,
                "title": normalize_step_name(step),
                "tool": "",
                "input": {},
                "error_strategy": "fail",
            })
        return normalized

    return validate_and_normalize_steps(data)


def plan_task_with_deepseek(user_input: str) -> list[dict[str, Any]]:
    last_error = None

    for attempt in range(1, 3):
        try:
            print(f"Planning attempt {attempt} for task: {user_input}")
            return call_deepseek_once(user_input)
        except Exception as e:
            last_error = e
            print(f"Planning attempt {attempt} failed: {e}")
            time.sleep(1)

    print(f"DeepSeek planning failed twice, fallback enabled: {last_error}")
    return fallback_steps(user_input)


def dedupe_search_results(results: list[dict[str, Any]]) -> list[dict[str, Any]]:
    seen = set()
    deduped = []

    for item in results:
        url = (item.get("url") or "").strip()
        if not url:
            continue
        if url in seen:
            continue
        seen.add(url)
        deduped.append(item)

    return deduped


def summarize_search_results(query: str, results: list[dict[str, Any]]) -> str:
    if not results:
        return f"未找到可摘要的搜索结果。查询词：{query}"

    simplified_results = []
    for item in results[:5]:
        simplified_results.append({
            "title": item.get("title", ""),
            "url": item.get("url", ""),
            "content": (item.get("content", "") or "")[:300],
        })

    prompt = {
        "query": query,
        "results": simplified_results,
    }

    try:
        completion = client.chat.completions.create(
            model=MODEL_NAME,
            messages=[
                {
                    "role": "system",
                    "content": (
                        "你是一个搜索结果整理助手。"
                        "请根据给定搜索结果，输出简明中文摘要。"
                        "输出要求："
                        "1. 先给出“结论摘要”小节，用 3 到 5 条 bullet 总结。"
                        "2. 再给出“关键来源”小节，列出标题和链接。"
                        "3. 不要编造结果，只能基于给定内容总结。"
                    ),
                },
                {
                    "role": "user",
                    "content": json.dumps(prompt, ensure_ascii=False),
                },
            ],
            temperature=0.2,
            max_tokens=1200,
        )

        text = (completion.choices[0].message.content or "").strip()
        if not text:
            return f"搜索结果摘要失败：DeepSeek 返回空内容。原始查询：{query}"

        return text

    except Exception as e:
        return f"搜索结果摘要失败：{e}"


def web_search_duckduckgo(query: str) -> str:
    url = "https://html.duckduckgo.com/html/"
    headers = {"User-Agent": "Mozilla/5.0"}

    resp = requests.post(
        url,
        data={"q": query},
        headers=headers,
        timeout=8,
    )
    resp.raise_for_status()

    soup = BeautifulSoup(resp.text, "html.parser")
    parsed_results = []

    for a in soup.select(".result__title a")[:8]:
        title = a.get_text(" ", strip=True)
        href = a.get("href", "")
        if title and href:
            parsed_results.append({
                "title": title,
                "url": href,
                "content": "",
            })

    parsed_results = dedupe_search_results(parsed_results)[:5]

    if not parsed_results:
        return f"web_search 已执行，但没有找到明显结果。查询词：{query}"

    summary = summarize_search_results(query, parsed_results)

    raw_refs = []
    for item in parsed_results:
        raw_refs.append(f"- {item['title']}\n  {item['url']}")

    return (
        "web_search 结果（DuckDuckGo）\n\n"
        f"{summary}\n\n"
        "原始来源：\n" +
        "\n".join(raw_refs)
    )


def web_search_tavily(query: str) -> str:
    if not TAVILY_API_KEY:
        return "web_search 执行失败：DuckDuckGo 不可用，且缺少 TAVILY_API_KEY"

    url = "https://api.tavily.com/search"
    headers = {"Content-Type": "application/json"}
    payload = {
        "api_key": TAVILY_API_KEY,
        "query": query,
        "search_depth": "basic",
        "max_results": 8,
        "include_answer": False,
        "include_raw_content": False,
    }

    resp = requests.post(url, headers=headers, json=payload, timeout=15)
    resp.raise_for_status()
    data = resp.json()

    results = data.get("results", [])
    parsed_results = []

    for item in results:
        parsed_results.append({
            "title": (item.get("title") or "").strip(),
            "url": (item.get("url") or "").strip(),
            "content": (item.get("content") or "").strip(),
        })

    parsed_results = dedupe_search_results(parsed_results)[:5]

    if not parsed_results:
        return f"web_search 已执行，但没有找到明显结果。查询词：{query}"

    summary = summarize_search_results(query, parsed_results)

    raw_refs = []
    for item in parsed_results:
        block = [f"- {item['title']}", f"  {item['url']}"]
        if item["content"]:
            block.append(f"  摘要片段：{item['content'][:180]}")
        raw_refs.append("\n".join(block))

    return (
        "web_search 结果（Tavily）\n\n"
        f"{summary}\n\n"
        "原始来源：\n" +
        "\n".join(raw_refs)
    )


def web_search(query: str) -> str:
    try:
        print(f"web_search: trying DuckDuckGo for query={query!r}")
        return web_search_duckduckgo(query)
    except Exception as duck_err:
        print(f"web_search: DuckDuckGo failed: {duck_err}")

        try:
            print(f"web_search: fallback to Tavily for query={query!r}")
            return web_search_tavily(query)
        except Exception as tavily_err:
            print(f"web_search: Tavily failed: {tavily_err}")
            return (
                "web_search 执行失败："
                f"DuckDuckGo 错误={duck_err}; "
                f"Tavily 错误={tavily_err}"
            )


def file_read(path_str: str) -> str:
    if not path_str:
        return "file_read 执行失败：缺少文件路径"

    if not is_path_in_allowed_dirs(path_str, ALLOWED_READ_DIRS):
        return f"file_read 执行失败：路径不在允许范围内 -> {path_str}"

    try:
        path = Path(path_str).resolve()
        if not path.exists():
            return f"file_read 执行失败：文件不存在 -> {path_str}"
        if not path.is_file():
            return f"file_read 执行失败：目标不是文件 -> {path_str}"

        content = path.read_text(encoding="utf-8", errors="ignore")
        content = content[:4000]
        return f"file_read 结果（{path_str}）：\n{content}"
    except Exception as e:
        return f"file_read 执行失败：{e}"


def list_dir(path_str: str) -> str:
    if not path_str:
        return "list_dir 执行失败：缺少目录路径"

    if not is_path_in_allowed_dirs(path_str, ALLOWED_READ_DIRS):
        return f"list_dir 执行失败：路径不在允许范围内 -> {path_str}"

    try:
        path = Path(path_str).resolve()
        if not path.exists():
            return f"list_dir 执行失败：目录不存在 -> {path_str}"
        if not path.is_dir():
            return f"list_dir 执行失败：目标不是目录 -> {path_str}"

        entries = sorted(path.iterdir(), key=lambda p: (p.is_file(), p.name.lower()))
        lines = []
        for entry in entries[:50]:
            prefix = "[DIR]" if entry.is_dir() else "[FILE]"
            lines.append(f"{prefix} {entry.name}")

        if not lines:
            return f"list_dir 结果（{path_str}）：目录为空"

        return f"list_dir 结果（{path_str}）：\n" + "\n".join(lines)
    except Exception as e:
        return f"list_dir 执行失败：{e}"


def file_write(path_str: str, content: str) -> str:
    if not path_str:
        return "file_write 执行失败：缺少文件路径"

    if not is_path_in_allowed_dirs(path_str, ALLOWED_WRITE_DIRS):
        return f"file_write 执行失败：路径不在允许范围内 -> {path_str}"

    try:
        path = Path(path_str).resolve()
        if path.exists() and path.is_dir():
            return f"file_write 执行失败：目标是目录，不是文件 -> {path_str}"

        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")
        return f"file_write 成功：已写入文件 -> {path_str}"
    except Exception as e:
        return f"file_write 执行失败：{e}"


def summarize_text(text: str) -> str:
    try:
        completion = client.chat.completions.create(
            model=MODEL_NAME,
            messages=[
                {
                    "role": "system",
                    "content": (
                        "你是一个文本整理助手。"
                        "请从给定内容中提炼关键要点。"
                        "输出 3 到 5 条简明中文 bullet。"
                        "不要编造信息，只能基于输入内容总结。"
                    ),
                },
                {
                    "role": "user",
                    "content": (text or "")[:4000],
                },
            ],
            temperature=0.2,
            max_tokens=800,
        )

        result = (completion.choices[0].message.content or "").strip()
        if not result:
            return "文本摘要失败：模型返回空内容"

        return "摘要结果：\n" + result
    except Exception as e:
        return f"文本摘要失败：{e}"


def shell_exec(command_str: str) -> str:
    if not command_str:
        return "shell_exec 执行失败：缺少命令"

    if any(token in command_str for token in ["|", ">", "<", ";", "&&", "||"]):
        return f"shell_exec 执行失败：命令包含不允许的控制符 -> {command_str}"

    try:
        parts = shlex.split(command_str)
    except Exception as e:
        return f"shell_exec 执行失败：命令解析失败 -> {e}"

    if not parts:
        return "shell_exec 执行失败：空命令"

    base_cmd = parts[0]

    if base_cmd not in SAFE_COMMANDS:
        return f"shell_exec 执行失败：命令不在白名单中 -> {base_cmd}"

    if any(token in DISALLOWED_TOKENS for token in parts):
        return f"shell_exec 执行失败：命令包含禁止词 -> {command_str}"

    try:
        completed = subprocess.run(
            parts,
            cwd="/workspace",
            capture_output=True,
            text=True,
            timeout=10,
        )
        stdout = (completed.stdout or "").strip()
        stderr = (completed.stderr or "").strip()

        output_parts = [
            f"shell_exec 命令：{command_str}",
            f"退出码：{completed.returncode}",
        ]

        if stdout:
            output_parts.append("标准输出：")
            output_parts.append(stdout[:4000])

        if stderr:
            output_parts.append("标准错误：")
            output_parts.append(stderr[:2000])

        return "\n".join(output_parts)
    except Exception as e:
        return f"shell_exec 执行失败：{e}"


def resolve_reference(ref: str, step_results: dict[int, dict[str, Any]]) -> Any:
    match = re.match(r"step:(\d+)\.(output|data)(?:\.(.+))?$", ref)
    if not match:
        return ref

    step_no = int(match.group(1))
    ref_type = match.group(2)
    sub_path = match.group(3)

    if step_no not in step_results:
        return ""

    step_result = step_results[step_no]

    if ref_type == "output":
        return step_result.get("output_text", "")

    if ref_type == "data":
        data = step_result.get("output_data", {})
        if not sub_path:
            return data

        current = data
        for part in sub_path.split("."):
            if isinstance(current, dict):
                current = current.get(part, "")
            else:
                return ""
        return current

    return ""


def resolve_step_input(step_input: dict[str, Any], step_results: dict[int, dict[str, Any]]) -> dict[str, Any]:
    resolved: dict[str, Any] = {}

    for key, value in step_input.items():
        if isinstance(value, str):
            if value.startswith("step:"):
                resolved[key] = resolve_reference(value, step_results)
                continue

            # 过渡期兼容旧占位符
            if value == "[file_content]":
                resolved[key] = step_results.get(1, {}).get("output_text", "")
                continue

            if value == "[summarized_content]":
                resolved[key] = step_results.get(2, {}).get("output_text", "")
                continue

        resolved[key] = value

    return resolved


def execute_tool(tool_name: str, tool_input: dict[str, Any]) -> dict[str, Any]:
    if tool_name == "file_read":
        path = tool_input.get("path") or tool_input.get("file_path", "")
        output_text = file_read(path)
        ok = not output_text.startswith("file_read 执行失败：")
