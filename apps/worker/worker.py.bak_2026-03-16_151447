            },
            "error": "" if ok else output_text,
        }

    if tool_name == "shell_exec":
        command = tool_input.get("command", "")
        output_text = shell_exec(command)
        ok = not output_text.startswith("shell_exec 执行失败：")
        return {
            "ok": ok,
            "summary": "命令执行成功" if ok else "命令执行失败",
            "output_text": output_text,
            "output_data": {
                "command": command,
                "stdout": output_text,
            },
            "error": "" if ok else output_text,
        }

    if tool_name == "summarize_text":
        text = tool_input.get("text", "")
        output_text = summarize_text(text)
