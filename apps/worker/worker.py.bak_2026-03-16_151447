            },
            "error": "" if ok else output_text,
        }

    return {
        "ok": False,
        "summary": "未知工具",
        "output_text": f"未知工具：{tool_name}",
        "output_data": {},
        "error": f"unknown tool: {tool_name}",
    }


def execute_step_legacy(step_name: str, user_input: str) -> str:
    file_keywords = ["读取文件", "查看文件", "分析文件", "打开文件", "读取产物", "查看产物"]
    dir_keywords = ["列出目录", "浏览目录", "查看文件列表", "列出文件"]
    analyze_keywords = [
        "分析文件", "整理要点", "提炼要点", "总结内容", "结构化输出",
        "整理关键内容", "查看目录文件的关键信息", "整理关键信息", "分析命令输出"
    ]
    write_keywords = ["写入文件", "保存文件", "输出到文件", "生成文件", "写到文件", "写入", "保存到", "输出到", "写结果到"]
    shell_keywords = ["执行命令", "运行命令", "shell", "终端命令", "执行终端命令"]
    search_keywords = ["搜索", "调研", "查资料", "检索"]

    if any(k in step_name for k in dir_keywords):
        path = extract_dir_from_text(step_name) or extract_dir_from_text(user_input)
        if not path or not path_looks_like_dir(path):
            return f"已执行步骤：{step_name}\n（列目录降级，原因：未识别到合法目录路径）"
        return list_dir(path)

    if any(k in step_name for k in file_keywords):
        path = extract_path_from_text(step_name) or extract_path_from_text(user_input)
        if not path or not path_looks_like_file(path):
            return f"已执行步骤：{step_name}\n（读取文件降级，原因：未识别到合法文件路径）"
        return file_read(path)

    if any(k in step_name for k in shell_keywords):
        command = extract_command_from_text(step_name) or extract_command_from_text(user_input)
        if not command:
            return f"已执行步骤：{step_name}\n（命令执行降级，原因：未识别到明确命令）"
        return shell_exec(command)

    if any(k in step_name for k in search_keywords):
        return web_search(f"{user_input} {step_name}")

    if any(k in step_name for k in analyze_keywords):
        return f"已执行步骤：{step_name}"

    if any(k in step_name for k in write_keywords):
        return f"已执行步骤：{step_name}\n（写文件降级，原因：旧版步骤不执行自动写文件）"

    return f"已执行步骤：{step_name}"


while True:
    try:
        conn = get_conn()
        cur = conn.cursor()

        cur.execute(
            """
            SELECT * FROM task_runs
            WHERE status = 'pending'
            ORDER BY id ASC
            LIMIT 1;
            """
        )
        task = cur.fetchone()

        if task:
            task_id = task["id"]

            cur.execute(
                """
                UPDATE task_runs
                SET status = 'running', updated_at = CURRENT_TIMESTAMP
                WHERE id = %s;
                """,
                (task_id,),
            )
            conn.commit()

            try:
                print(f"Task {task_id}: planning with DeepSeek")
                planned_steps = plan_task_with_deepseek(task["user_input"])

                create_steps(cur, task_id, planned_steps)
                conn.commit()

                step_outputs: list[str] = []
                step_results: dict[int, dict[str, Any]] = {}

                for idx, step in enumerate(planned_steps, start=1):
                    step_order = step.get("step_order", idx)
                    title = step.get("title", f"步骤{idx}")
                    tool_name = step.get("tool", "")
                    raw_input = step.get("input", {})
                    error_strategy = step.get("error_strategy", "fail")

                    resolved_input = resolve_step_input(raw_input, step_results)

                    cur.execute(
                        """
                        UPDATE task_steps
                        SET status = 'running', updated_at = CURRENT_TIMESTAMP
                        WHERE task_id = %s AND step_order = %s;
                        """,
                        (task_id, step_order),
                    )
                    conn.commit()

                    if not tool_name:
                        output_text = execute_step_legacy(title, task["user_input"])
                        tool_result = {
                            "ok": True,
                            "summary": title,
                            "output_text": output_text,
                            "output_data": {},
                            "error": "",
                        }
                    else:
                        tool_result = execute_tool(tool_name, resolved_input)
                        output_text = tool_result["output_text"]

                    final_status = "completed" if tool_result["ok"] else "failed"

                    cur.execute(
                        """
                        UPDATE task_steps
                        SET status = %s,
                            tool_name = %s,
                            input_payload = %s,
                            output_payload = %s,
                            output_data = %s,
                            error_message = %s,
                            error_strategy = %s,
                            updated_at = CURRENT_TIMESTAMP
                        WHERE task_id = %s AND step_order = %s;
                        """,
                        (
                            final_status,
                            tool_name,
                            json.dumps(resolved_input, ensure_ascii=False),
                            tool_result["output_text"],
                            json.dumps(tool_result["output_data"], ensure_ascii=False),
                            tool_result["error"],
                            error_strategy,
                            task_id,
                            step_order,
                        ),
                    )
                    conn.commit()

                    step_results[step_order] = tool_result
                    step_outputs.append(tool_result["output_text"])

                    if not tool_result["ok"] and error_strategy != "continue":
                        raise RuntimeError(f"Step {step_order} failed: {tool_result['error']}")

                print(f"Task {task_id}: writing artifact")
                artifact_path = write_artifact(task_id, task["user_input"], step_outputs)

                final_result = "\n".join(step_outputs) + f"\n\n产出文件：{artifact_path}"

                print(f"Task {task_id}: updating task_runs to completed")
                cur.execute(
                    """
                    UPDATE task_runs
                    SET status = 'completed',
                        result = %s,
                        updated_at = CURRENT_TIMESTAMP
                    WHERE id = %s;
                    """,
                    (final_result, task_id),
                )
                conn.commit()

                print(f"Task {task_id} completed with steps")

            except Exception as e:
                cur.execute(
                    """
                    UPDATE task_runs
                    SET status = 'failed',
                        error_message = %s,
                        updated_at = CURRENT_TIMESTAMP
                    WHERE id = %s;
                    """,
                    (str(e), task_id),
                )
                conn.commit()
                print(f"Task {task_id} failed: {e}")

        cur.close()
        conn.close()

    except Exception as e:
        print(f"Worker loop error: {e}")

    time.sleep(3)