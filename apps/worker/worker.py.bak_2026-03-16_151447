            },
            "error": "" if ok else output_text,
        }

    if tool_name == "web_search":
        query = tool_input.get("query", "")
        output_text = web_search(query)
        ok = not output_text.startswith("web_search 执行失败：")
        return {
            "ok": ok,
            "summary": "成功搜索资料" if ok else "搜索失败",
            "output_text": output_text,
            "output_data": {
                "query": query,
                "results_text": output_text,
            },
            "error": "" if ok else output_text,
        }

    if tool_name == "file_write":
        path = tool_input.get("path") or tool_input.get("file_path", "")
        content = tool_input.get("content", "")
        output_text = file_write(path, content)
        ok = not output_text.startswith("file_write 执行失败：")
        return {
            "ok": ok,
            "summary": "成功写入文件" if ok else "写文件失败",
            "output_text": output_text,
            "output_data": {
